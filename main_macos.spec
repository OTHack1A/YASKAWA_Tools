        'docs.points',
        'docs.ga500_params',
        'docs.logdata',
        'docs.pdf_header',
        'docs.ipnet',
        'docs.ifpanel',
        'docs.flowchart',
        'docs.posvar',
        'gui.ifpanel_view',
        'gui.posvar_view',
        'gui.flowchart_view',
        'gui.help_view',

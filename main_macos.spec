pyz = PYZ(a.pure)

exe = EXE(
    pyz,
    a.scripts,
    a.binaries,
    a.datas,
    [],
    name='YaskawaTools',
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=False,          # UPX non supportato su macOS arm64
